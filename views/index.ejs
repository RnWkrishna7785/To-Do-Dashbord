<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>To-Do Dashboard (Array Version)</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
    <div class="container mx-auto px-4 py-8 max-w-4xl">
        <div class="flex justify-between items-center mb-10 bg-white p-6 rounded-2xl shadow-sm border">
            <h2 class="text-3xl font-extrabold text-gray-800 uppercase">🎯 My Tasks</h2>
            <a href="/add" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-6 rounded-xl transition">
                + Add New Task
            </a>
        </div>

        <div class="bg-white shadow-xl rounded-2xl overflow-hidden">
            <table class="w-full text-left">
                <thead class="bg-gray-800 text-white">
                    <tr>
                        <th class="py-4 px-6">Task</th>
                        <th class="py-4 px-6 text-center">Status</th>
                        <th class="py-4 px-6 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="text-gray-600">
                    <% todos.forEach(todo => { %>
                    <tr class="border-b hover:bg-indigo-50 transition">
                        <td class="py-4 px-6 font-semibold"><%= todo.task %></td>
                        <td class="py-4 px-6 text-center">
                            <span class="px-3 py-1 rounded-full text-xs font-bold <%= todo.status === 'Completed' ? 'bg-green-100 text-green-600' : 'bg-orange-100 text-orange-600' %>">
                                <%= todo.status %>
                            </span>
                        </td>
                        <td class="py-4 px-6 text-right space-x-2">
                            <a href="/edit/<%= todo.id %>" class="text-blue-600 hover:underline">Edit</a>
                            <a href="/delete/<%= todo.id %>" onclick="return confirm('Delete?')" class="text-red-600 hover:underline">Delete</a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            <% if(todos.length === 0) { %>
                <div class="p-10 text-center text-gray-400">No tasks yet!</div>
            <% } %>
        </div>
    </div>
</body>
</html>