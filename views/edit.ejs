<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Task</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-blue-50 flex items-center justify-center min-h-screen">
    <div class="bg-white p-8 rounded-3xl shadow-2xl w-full max-w-md">
        <h2 class="text-2xl font-black mb-6 text-center">✏️ Edit Task</h2>
        
        <form action="/update/<%= todo.id %>" method="post" class="space-y-6">
            <div>
                <label class="block text-sm font-bold mb-2">Task Description</label>
                <input type="text" name="task" value="<%= todo.task %>" required
                    class="w-full px-4 py-3 rounded-xl border focus:ring-2 focus:ring-blue-200 outline-none">
            </div>

            <div>
                <label class="block text-sm font-bold mb-2">Status</label>
                <select name="status" class="w-full px-4 py-3 rounded-xl border bg-gray-50">
                    <option value="Pending" <%= todo.status == 'Pending' ? 'selected' : '' %>>Pending</option>
                    <option value="Completed" <%= todo.status == 'Completed' ? 'selected' : '' %>>Completed</option>
                </select>
            </div>

            <div class="flex flex-col gap-3">
                <button type="submit" class="bg-blue-600 text-white font-bold py-3 rounded-xl hover:bg-blue-700 transition">
                    Update Changes
                </button>
                <a href="/" class="text-center text-gray-400 text-sm">Cancel</a>
            </div>
        </form>
    </div>
</body>
</html>